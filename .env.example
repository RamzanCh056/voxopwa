# Copy this file to .env and fill in your keys
# Set these same variables in your Railway project's Variables tab
#
# Only put PUBLIC, safe-to-expose keys here (VITE_ prefix = bundled into the
# client). Never put Stripe secret keys (sk_live_/sk_test_) or webhook signing
# secrets (whsec_) in this file — those belong in functions/.env.example
# (price IDs only) or Firebase Functions secrets (the actual secret values).
#
# Secrets stored in Firebase, NOT here (set via `firebase functions:secrets:set`):
#   STRIPE_SECRET_KEY     (sk_live_...)
#   STRIPE_WEBHOOK_SECRET (whsec_...)

VITE_OPENAI_API_KEY=sk-proj-...your-openai-key-here...
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...your-stripe-publishable-key-here...

PRICE_MONTHLY=prod_UkDu6iLd2SHakW
PRICE_QUARTERLY=prod_UkDvWspPAMYNNf
PRICE_YEARLY=prod_UkDvzvm4lODIlm

# Copy this file to functions/.env and fill in your Stripe Price IDs.
# Price IDs (price_...) are not secret — safe to commit as placeholders here,
# but use your real values in the actual functions/.env (gitignored).
#
# The Stripe SECRET key and webhook signing secret are NOT set here — they
# are stored only in Firebase Functions secrets:
#   firebase functions:secrets:set STRIPE_SECRET_KEY
#   firebase functions:secrets:set STRIPE_WEBHOOK_SECRET

PRICE_MONTHLY=price_...30-day-plan-price-id...
PRICE_QUARTERLY=price_...90-day-plan-price-id...
PRICE_YEARLY=price_...1-year-plan-price-id...

# Top-up add-on — not yet configured/in use
# PRICE_TOPUP=price_...topup-300-minutes-price-id...
